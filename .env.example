# AI Usage Dashboard — Environment Variables
# Copy this file to .env and fill in your credentials.
# All keys are optional; missing keys show graceful empty states.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# DB_PATH=data/dashboard.db

# ── Auto-refresh interval ────────────────────────────────────────────────────
REFRESH_INTERVAL_MINUTES=15

# ── Provider API keys ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_ORG_ID=org-...        # Enables org-level usage data
# OPENAI_PROJECT_ID=proj-...   # Optional project scope

# ANTHROPIC_API_KEY=sk-ant-...

# GEMINI_API_KEY=AIzaSy...

# MISTRAL_API_KEY=...

# OPENROUTER_API_KEY=sk-or-...

# ── Experimental endpoints ────────────────────────────────────────────────────
# Set ENABLE_EXPERIMENTAL=true to enable community-discovered endpoints.
# These are never required and may break without notice.
# ENABLE_EXPERIMENTAL=false

# Claude Code session cookie (requires ENABLE_EXPERIMENTAL=true)
# CLAUDE_CODE_SESSION=...
# CLAUDE_CODE_ORG_ID=...       # Optional Claude org UUID; auto-discovered if omitted

# Mistral Vibe console session cookie (requires ENABLE_EXPERIMENTAL=true)
# MISTRAL_VIBE_SESSION=...

# Google Cloud project for quota metrics (requires ENABLE_EXPERIMENTAL=true)
# GOOGLE_CLOUD_PROJECT=my-project-id

# ── Subscription pricing (for savings estimates) ──────────────────────────────
# Monthly prices in USD. Set to 0 to disable savings calculation for a tool.
# CLAUDE_CODE_SUBSCRIPTION_PRICE=20.0
# CLAUDE_CODE_PLAN_NAME=Pro
# CODEX_SUBSCRIPTION_PRICE=200.0
# CODEX_PLAN_NAME=Pro
# MISTRAL_VIBE_SUBSCRIPTION_PRICE=19.99
# MISTRAL_VIBE_PLAN_NAME=Pro

# Per-token API pricing assumptions (USD per 1K tokens)
# CLAUDE_API_COST_PER_1K_TOKENS=0.015
# OPENAI_API_COST_PER_1K_TOKENS=0.01
# MISTRAL_API_COST_PER_1K_TOKENS=0.002
